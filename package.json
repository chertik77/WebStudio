{
  "name": "vite-project",
  "version": "0.0.0",
  "devDependencies": {
    "eslint": "^8.51.0",
    "htmlhint": "^1.1.4",
    "stylelint": "^15.10.3",
    "stylelint-config-standard": "^34.0.0",
    "vite": "^4.4.5",
    "vite-plugin-full-reload": "^1.0.5"
  },
  "private": true,
  "scripts": {
    "d": "npm run htmllint && npm run stlint && npm run jslint && vite --open",
    "htmllint": "npx htmlhint **/*.html",
